# ============================================================
# SENTINEL SIEM – Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# URL of the Node.js backend server
# Default: http://localhost:3001
VITE_API_URL=http://localhost:3001

# ── Supabase direct connection (optional) ─────────────────
# If you want to query Supabase directly from the frontend
# (bypassing the proxy backend), set these values.
# Get them from: Supabase Dashboard → Settings → API
#
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
