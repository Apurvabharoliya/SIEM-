# ============================================================
# SENTINEL SIEM – Backend Server Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# Port the backend server listens on
PORT=3001

# ── Supabase Configuration ─────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
#
# SUPABASE_URL:     Project URL (e.g. https://abc123.supabase.co)
# SUPABASE_ANON_KEY: Public anon key (safe for client-side use)
# SUPABASE_SERVICE_ROLE_KEY: Secret service_role key (server-only!)
#                          NEVER expose this to the frontend!

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
